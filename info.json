{
    "name": "PowerOverload",
    "version": "2.1.6",
    "title": "Power Overload",
    "author": "Xorimuth",
    "homepage": "https://discord.gg/pkJc4v9nfT",
    "description": "Performant, semi-realistic power distribution overhaul.\nPower poles can explode if the total electrical consumption on the network is too high. Use transformers to separate networks so that subnetworks do not take more power than they can handle.",
    "factorio_version": "2.1",
    "dependencies": [
      "base >= 2.1.0",
      "? quality",
      "? space-age",
      "(?) aai-industry",
      "(?) bzaluminum",
      "(?) bzlead",
      "(?) bzgas",
      "(?) PickerDollies",
      "(?) pyalternativeenergy"
    ],
    "--x-known-integrations": [
      "(?) Advanced_Electric",
      "(?) AdvancedSubstation",
      "(?) Bio_Industries",
      "(?) bobpower",
      "(?) cargo-ships",
      "(?) FactorioExtended-Plus-Power",
      "(?) fixLargeElectricPole",
      "(?) fpp",
      "(?) Krastorio2",
      "(?) Krastorio2-spaced-out",
      "(?) Lighted-Poles-Plus",
      "(?) omnimatter_energy",
      "(?) pycoalprocessing",
      "(?) space-exploration"
    ],
    "package": {
      "ignore": ["resources/*"]
    }
  }
